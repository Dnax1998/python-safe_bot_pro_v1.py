import json

# Generator bazy 200 posiłków
db = {
    "Śniadanie": [],
    "Drugie Śniadanie": [],
    "Obiad": [],
    "Podwieczorek": [],
    "Kolacja": []
}

templates = {
    "Śniadanie": [
        ("Owsianka z {0}", 350, ["płatki", "{0}", "mleko"]),
        ("Jajecznica z {0}", 400, ["jajka", "{0}", "masło"]),
        ("Tosty z {0}", 380, ["chleb", "{0}", "ser"]),
        ("Placki z {0}", 420, ["mąka", "{0}", "jajko"]),
        ("Kanapki z {0}", 350, ["chleb", "{0}", "warzywa"])
    ],
    "Drugie Śniadanie": [
        ("Jogurt z {0}", 200, ["jogurt", "{0}"]),
        ("Sałatka owocowa z {0}", 180, ["owoce", "{0}"]),
        ("Serek z {0}", 220, ["serek wiejski", "{0}"]),
        ("Smoothie z {0}", 150, ["banan", "{0}"]),
        ("Kefir i {0}", 160, ["kefir", "{0}"])
    ],
    "Obiad": [
        ("Kurczak z {0}", 600, ["pierś z kurczaka", "{0}", "ryż"]),
        ("Makaron z {0}", 550, ["makaron", "{0}", "sos"]),
        ("Pieczony {0}", 500, ["{0}", "ziemniaki", "surówka"]),
        ("Risotto z {0}", 580, ["ryż", "{0}", "parmezan"]),
        ("Gulasz z {0}", 620, ["mięso", "{0}", "kasza"])
    ],
    "Podwieczorek": [
        ("Garść {0}", 150, ["{0}"]),
        ("Baton proteinowy {0}", 200, ["baton", "{0}"]),
        ("Jabłko i {0}", 120, ["jabłko", "{0}"]),
        ("Kisiel z {0}", 100, ["kisiel", "{0}"]),
        ("Budyń {0}", 180, ["mleko", "{0}"])
    ],
    "Kolacja": [
        ("Sałatka z {0}", 300, ["mix sałat", "{0}", "oliwa"]),
        ("Twarożek z {0}", 250, ["twaróg", "{0}", "jogurt"]),
        ("Omlet z {0}", 320, ["jajka", "{0}"]),
        ("Zupa krem z {0}", 280, ["warzywa", "{0}"]),
        ("Wrapy z {0}", 350, ["tortilla", "{0}", "sałata"])
    ]
}

# Składniki do rotacji
ingredients = [
    "borówkami", "truskawkami", "bananem", "masłem orzechowym", "miodem", "orzechami", "szynką", "serem", "pomidorem", "szczypiorkiem",
    "awokado", "łososiem", "tuńczykiem", "kurczakiem", "indykiem", "wołowiną", "tofu", "cukinią", "bakłażanem", "papryką",
    "szpinakiem", "fetą", "mozzarellą", "pestkami dyni", "chia", "mango", "jabłkiem", "gruszką", "malinami", "brzoskwinią",
    "kiełkami", "oliwkami", "hummusem", "jajkiem", "pieczarkami", "bazylią", "pesto", "soczewicą", "cieciorką", "dynią"
]

for category, items in templates.items():
    for i in range(40):
        tmpl, base_kcal, base_ing = items[i % len(items)]
        ing_name = ingredients[i]
        is_fish = "łososiem" in ing_name or "tuńczykiem" in ing_name or "dorszem" in ing_name
        
        name = tmpl.format(ing_name)
        final_ing = [item.format(ing_name) for item in base_ing]
        
        db[category].append({
            "name": name,
            "kcal": base_kcal + (i * 2),
            "p": 20 + (i % 5),
            "f": 10 + (i % 3),
            "w": 30 + (i % 10),
            "fish": is_fish,
            "ing": final_ing,
            "steps": [
                f"Przygotuj wszystkie składniki: {', '.join(final_ing)}.",
                f"Połącz główne składniki i poddaj obróbce termicznej jeśli wymagane.",
                f"Dopraw do smaku solą, pieprzem i ulubionymi ziołami.",
                f"Podawaj na ciepło lub zimno w zależności od preferencji."
            ]
        })

with open('posilki.json', 'w', encoding='utf-8') as f:
    json.dump(db, f, ensure_ascii=False, indent=2)
